# Signal Desk - Phase 1 MVP Environment Configuration
# Copy to .env and fill in values

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=signal_desk
POSTGRES_USER=signal_desk
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Primary Provider: Polygon.io (required for price data)
POLYGON_API_KEY=your_polygon_api_key_here

# Application
APP_NAME=Signal Desk
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=generate_a_random_secret_key_here
CORS_ORIGINS=http://localhost:3000

# Cache TTL (seconds)
CACHE_TTL_PRICE=60
CACHE_TTL_TICKER=3600
